                {
                  "key": "shiftCode",
                  "value": "{{SHIFT_CODE}}",
                  "description": "Filter by shift code, e.g. SHIFT_A (optional)"
                },
                {
                  "key": "status",
                  "value": "{{STATUS}}",
                  "description": "Filter by part status: OK | NG (optional)"
                },
                {
                  "key": "barcode",
                  "value": "{{BARCODE}}",
                  "description": "Filter by exact barcode / part ID (optional)"
                },
                {
                  "key": "page",
                  "value": "1",
                  "description": "Page number"
                },
                {
                  "key": "pageSize",
                  "value": "{{PAGE_SIZE}}",
                  "description": "Rows per page; keep small for Postman smoke tests"
                },
                {
                  "key": "fast",
                  "value": "{{FAST_MODE}}",
                  "description": "true = quick Postman mode; skips PLC-heavy enrichment to avoid nginx 504"
                }
              ]
            },
            "description": "Full filtered call — uses all available filters.\nDisable any query param (uncheck in Postman) to remove that filter.\n\nResponse includes:\n  rows[]           — production records\n  metrics          — OK/NG counts, PLC summary\n  pagination       — page / totalRows / totalPages\n  availableShifts  — shift definitions"
          },
          "event": [
