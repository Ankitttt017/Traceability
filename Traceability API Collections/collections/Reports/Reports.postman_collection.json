    {
      "name": "2. Export Full Report",
      "description": "POST /reports/report/export-full\n\nDownloads an Excel (.xlsx) workbook with ALL production records for the date range.\n\nRequired body fields: filters.dateFrom, filters.dateTo\nOptional body fields: filters.machineId, lineName, shiftCode, status, barcode",
      "item": [
        {
          "name": "Export Full Report — Date Range Only",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{TOKEN}}"
              }
            ],
            "url": {
              "raw": "{{BASE_URL}}/reports/report/export-full",
              "host": [
                "{{BASE_URL}}"
              ],
              "path": [
                "reports",
                "report",
                "export-full"
              ]
            },
            "description": "Simplest export — all data for the date range, no extra filters.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"filters\": {\n    \"dateFrom\": \"{{DATE_FROM}}\",\n    \"dateTo\":   \"{{DATE_TO}}\"\n  }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [
            {
              "name": "200 — Excel file download",
              "originalRequest": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  },
                  {
                    "key": "Authorization",
                    "value": "Bearer {{TOKEN}}"
                  }
                ],
                "url": {
                  "raw": "{{BASE_URL}}/reports/report/export-full",
                  "host": [
                    "{{BASE_URL}}"
                  ],
                  "path": [
                    "reports",
                    "report",
                    "export-full"
                  ]
                },
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"filters\": {\n    \"dateFrom\": \"{{DATE_FROM}}\",\n    \"dateTo\":   \"{{DATE_TO}}\"\n  }\n}",
                  "options": {
                    "raw": {
                      "language": "json"
                    }
                  }
                }
              },
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "text",
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet"
                },
                {
                  "key": "Content-Disposition",
                  "value": "attachment; filename=\"full_report.xlsx\""
                }
              ],
              "cookie": [],
              "body": "<binary Excel file>"
            }
          ]
        },
        {
          "name": "Export Full Report — With All Filters",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{TOKEN}}"
              }
            ],
            "url": {
              "raw": "{{BASE_URL}}/reports/report/export-full",
              "host": [
                "{{BASE_URL}}"
              ],
              "path": [
                "reports",
                "report",
                "export-full"
              ]
            },
            "description": "Full filtered export.\nRemove any filter key you don't need — all fields except dateFrom/dateTo are optional.\n\nreportConfig controls the Excel header/branding — safe to leave as-is.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"filters\": {\n    \"dateFrom\":  \"{{DATE_FROM}}\",\n    \"dateTo\":    \"{{DATE_TO}}\",\n    \"machineId\": \"{{MACHINE_ID}}\",\n    \"lineName\":  \"{{LINE_NAME}}\",\n    \"shiftCode\": \"{{SHIFT_CODE}}\",\n    \"status\":    \"{{STATUS}}\",\n    \"barcode\":   \"{{BARCODE}}\"\n  },\n  \"reportConfig\": {\n    \"companyName\":  \"BMW Group\",\n    \"plantName\":    \"Gen-6 Bawal Plant\",\n    \"reportTitle\":  \"Full Production Report\",\n    \"showLogo\":     true,\n    \"showDate\":     true,\n    \"showShift\":    true,\n    \"showMachine\":  true\n  }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Response is Excel or JSON', () => {",
                  "  const ct = pm.response.headers.get('Content-Type') || '';",
                  "  pm.expect(ct.includes('spreadsheetml') || ct.includes('octet-stream') || ct.includes('json')).to.be.true;",
                  "});"
                ]
              }
            }
          ],
          "response": [
            {
              "name": "200 — Excel file download",
              "originalRequest": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  },
                  {
                    "key": "Authorization",
                    "value": "Bearer {{TOKEN}}"
                  }
                ],
                "url": {
                  "raw": "{{BASE_URL}}/reports/report/export-full",
                  "host": [
                    "{{BASE_URL}}"
                  ],
                  "path": [
                    "reports",
                    "report",
                    "export-full"
                  ]
                },
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"filters\": {\n    \"dateFrom\":  \"{{DATE_FROM}}\",\n    \"dateTo\":    \"{{DATE_TO}}\",\n    \"machineId\": \"{{MACHINE_ID}}\",\n    \"lineName\":  \"{{LINE_NAME}}\",\n    \"shiftCode\": \"{{SHIFT_CODE}}\",\n    \"status\":    \"{{STATUS}}\",\n    \"barcode\":   \"{{BARCODE}}\"\n  }\n}",
                  "options": {
                    "raw": {
                      "language": "json"
                    }
                  }
                }
              },
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "text",
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet"
                },
                {
                  "key": "Content-Disposition",
                  "value": "attachment; filename=\"full_report.xlsx\""
                }
              ],
              "cookie": [],
              "body": "<binary Excel file>"
            }
          ]
        }
      ]
    },
