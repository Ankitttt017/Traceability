                  "pm.test('Has pagination info', () => pm.expect(pm.response.json()).to.have.property('pagination'));",
                  "pm.test('Has metrics',         () => pm.expect(pm.response.json()).to.have.property('metrics'));"
                ]
              }
            }
          ],
          "response": [
            {
              "name": "200 Success",
              "originalRequest": {
