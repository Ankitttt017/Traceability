            "url": {
              "raw": "{{BASE_URL}}/reports/report/data?dateFrom={{DATE_FROM}}&dateTo={{DATE_TO}}&machineId={{MACHINE_ID}}&lineName={{LINE_NAME}}&shiftCode={{SHIFT_CODE}}&status={{STATUS}}&barcode={{BARCODE}}&page=1&pageSize={{PAGE_SIZE}}&fast={{FAST_MODE}}",
              "host": [
                "{{BASE_URL}}"
