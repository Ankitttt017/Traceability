{
  "info": {
    "name": "Reports",
    "description": "Step 2 - All Report APIs.\n\nRun Login.postman_collection.json FIRST to populate {{TOKEN}}.\n\nFolders inside:\n  1. Get Report Data - view paginated data with filters\n  2. Export Full - download Full Excel report\n  3. Export NG - download NG-only Excel report\n  4. Export Parts - download Parts Excel report\n  5. Export Audit - download Audit Excel report\n\nDate-range filter variables:\n  {{DATE_FROM}} e.g. 2026-07-10T06:00:00\n  {{DATE_TO}}   e.g. 2026-07-11T06:00:00\n\nImportant: use full datetime values. A date-only value like 2026-07-09 means 2026-07-09 00:00:00, so records later that day can be excluded.\n\nFor Postman smoke tests, report data requests use fast=true by default. Fast mode skips PLC-heavy enrichment and helps avoid nginx 504 timeouts on large ranges.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "BASE_URL",
      "value": "http://192.168.100.136:9090/api/v1",
      "description": "Server base URL — change for DEV / UAT / PROD"
    },
    {
      "key": "TOKEN",
      "value": "",
      "description": "Paste your JWT token here OR run Login collection first to auto-fill"
    },
    {
      "key": "DATE_FROM",
      "value": "2026-07-10T06:00:00",
      "description": "Start datetime for report filter - format YYYY-MM-DDTHH:mm:ss. MES day usually starts at 06:00."
    },
    {
      "key": "DATE_TO",
      "value": "2026-07-11T06:00:00",
      "description": "End datetime for report filter - use next day 06:00 to include the full MES production day."
    },
    {
      "key": "FAST_MODE",
      "value": "true",
      "description": "Use true for quick Postman testing. Set false or remove fast param for full PLC-enriched report data."
    },
    {
      "key": "PAGE_SIZE",
      "value": "25",
      "description": "Rows per page for report data. Keep small in Postman to avoid nginx timeout."
    },
    {
      "key": "MACHINE_ID",
      "value": "1",
      "description": "Machine ID to filter by (optional — delete param to get all machines)"
    },
    {
      "key": "LINE_NAME",
      "value": "LINE-1",
      "description": "Production line name to filter by (optional)"
    },
    {
      "key": "SHIFT_CODE",
      "value": "SHIFT_A",
      "description": "Shift code to filter by — e.g. SHIFT_A, SHIFT_B, SHIFT_C (optional)"
    },
    {
      "key": "STATUS",
      "value": "OK",
      "description": "Part status filter: OK | NG  (optional — remove param to get all)"
    },
    {
      "key": "BARCODE",
      "value": "PART-0001",
      "description": "Exact barcode / part ID to search (optional)"
    },
    {
      "key": "USER_ID",
      "value": "1",
      "description": "User ID for audit report filter (optional)"
    }
  ],
  "item": [
    {
      "name": "1. Get Report Data",
      "description": "GET /reports/report/data\n\nReturns paginated production rows + metrics + shift list.\nUse query params to filter the data.\n\nRequired: dateFrom, dateTo\nOptional: machineId, lineName, shiftCode, status, barcode, page, pageSize",
      "item": [
        {
          "name": "Get Report Data — Date Range Only",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{TOKEN}}"
              }
            ],
            "url": {
              "raw": "{{BASE_URL}}/reports/report/data?dateFrom={{DATE_FROM}}&dateTo={{DATE_TO}}&fast={{FAST_MODE}}&page=1&pageSize={{PAGE_SIZE}}",
              "host": [
                "{{BASE_URL}}"
              ],
              "path": [
                "reports",
                "report",
                "data"
              ],
              "query": [
                {
                  "key": "dateFrom",
                  "value": "{{DATE_FROM}}",
                  "description": "Start datetime (YYYY-MM-DDTHH:mm:ss) — REQUIRED"
                },
                {
                  "key": "dateTo",
                  "value": "{{DATE_TO}}",
                  "description": "End datetime (YYYY-MM-DDTHH:mm:ss) — REQUIRED. Use next day 06:00 for a full MES day."
                },
                {
                  "key": "fast",
                  "value": "{{FAST_MODE}}",
                  "description": "true = quick Postman mode; skips PLC-heavy enrichment to avoid nginx 504"
                },
                {
                  "key": "page",
                  "value": "1",
                  "description": "Page number"
                },
                {
                  "key": "pageSize",
                  "value": "{{PAGE_SIZE}}",
                  "description": "Rows per page; keep small for Postman smoke tests"
                }
              ]
            },
            "description": "Simplest call — returns all production data for the date range with no extra filters."
          },
          "response": [
            {
              "name": "200 Success",
              "originalRequest": {
                "method": "GET",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "Bearer {{TOKEN}}"
                  }
                ],
                "url": {
                  "raw": "{{BASE_URL}}/reports/report/data?dateFrom={{DATE_FROM}}&dateTo={{DATE_TO}}&fast={{FAST_MODE}}&page=1&pageSize={{PAGE_SIZE}}",
                  "host": [
                    "{{BASE_URL}}"
                  ],
                  "path": [
                    "reports",
                    "report",
                    "data"
                  ],
                  "query": [
                    {
                      "key": "dateFrom",
                      "value": "{{DATE_FROM}}"
                    },
                    {
                      "key": "dateTo",
                      "value": "{{DATE_TO}}"
                    },
                    {
                      "key": "fast",
                      "value": "{{FAST_MODE}}",
                      "description": "true = quick Postman mode; skips PLC-heavy enrichment to avoid nginx 504"
                    },
                    {
                      "key": "page",
                      "value": "1",
                      "description": "Page number"
                    },
                    {
                      "key": "pageSize",
                      "value": "{{PAGE_SIZE}}",
                      "description": "Rows per page; keep small for Postman smoke tests"
                    }
                  ]
                }
              },
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "cookie": [],
              "body": "{\n  \"rows\": [],\n  \"metrics\": {\n    \"totalParts\": 120,\n    \"okCount\": 110,\n    \"ngCount\": 10,\n    \"plcShotSummary\": { \"totalProduction\": 120, \"okShot\": 110, \"warmUpShot\": 5, \"offShot\": 5 }\n  },\n  \"pagination\": {\n    \"page\": 1,\n    \"pageSize\": 50,\n    \"totalRows\": 120,\n    \"totalPages\": 3,\n    \"hasNextPage\": true,\n    \"hasPrevPage\": false\n  },\n  \"availableShifts\": []\n}"
            }
          ],
          "description": "\n\nPostman tip: keep fast=true for smoke tests. Set fast=false for full PLC-enriched results."
        },
        {
          "name": "Get One Part Full Details - Date Range",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{TOKEN}}"
              }
            ],
            "url": {
              "raw": "{{BASE_URL}}/reports/report/data?dateFrom={{DATE_FROM}}&dateTo={{DATE_TO}}&barcode={{BARCODE}}&fast=false&page=1&pageSize=50",
              "host": [
                "{{BASE_URL}}"
              ],
              "path": [
                "reports",
                "report",
                "data"
              ],
              "query": [
                {
                  "key": "dateFrom",
                  "value": "{{DATE_FROM}}",
                  "description": "Start datetime (YYYY-MM-DDTHH:mm:ss)"
                },
                {
                  "key": "dateTo",
                  "value": "{{DATE_TO}}",
                  "description": "End datetime (YYYY-MM-DDTHH:mm:ss)"
                },
                {
                  "key": "barcode",
                  "value": "{{BARCODE}}",
                  "description": "Part ID / customer QR / shot number to fetch full details for one part"
                },
                {
                  "key": "fast",
                  "value": "false",
                  "description": "false = full report-page style details for this part"
                },
                {
                  "key": "page",
                  "value": "1",
                  "description": "Page number"
                },
                {
                  "key": "pageSize",
                  "value": "50",
                  "description": "Enough rows to include all station details for one part"
                }
              ]
            },
            "description": "Use this when you need all report-page details for one specific part inside a date range. Because barcode is focused, the backend keeps full PLC/leaktest enrichment enabled."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Has rows array', function () { pm.expect(pm.response.json()).to.have.property('rows'); });",
                  "pm.test('Full mode for part details', function () { pm.expect(pm.response.json().reportMode).to.eql('FULL'); });"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "Get Report Data — With All Filters",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{TOKEN}}"
