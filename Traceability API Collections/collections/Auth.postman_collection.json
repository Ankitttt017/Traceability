            }
          ],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "",
                  "if (res.token) {",
                  "  pm.environment.set(\"TOKEN\", res.token);",
                  "}",
                  "",
                  "if (res.data?.token) {",
                  "  pm.environment.set(\"TOKEN\", res.data.token);",
                  "}",
                  "",
                  "if (res.accessToken) {",
                  "  pm.environment.set(\"TOKEN\", res.accessToken);",
                  "}"
                ]
              }
            }
          ]
